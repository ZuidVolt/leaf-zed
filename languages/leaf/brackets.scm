; HTML tag angle brackets
("<" @open ">" @close)
("</" @open ">" @close)
("<" @open "/>" @close)

; Leaf expression delimiters
("#(" @open ")" @close)

; General brackets
("(" @open ")" @close)
("{" @open "}" @close)
("[" @open "]" @close)

; HTML attribute quotes
("\"" @open "\"" @close)
("'" @open "'" @close)
